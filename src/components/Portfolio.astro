---
// PORTFOLIO IMAGES
// TODO: Broaden this set. These 3 shots are all the same residential block in
// one neighborhood — add variety (commercial sites, riverfront, twilight,
// different towns) as new flights come in. To add a shot:
//   1. Drop a web-sized photo into public/images/portfolio/ (~1600px wide, JPEG q80)
//   2. Add an entry below with its src, label, and caption
const shots = [
  { src: '/images/portfolio/backyard-front-view.jpg', label: 'Neighborhood Context', caption: 'Wide establishing shot with river and skyline behind' },
  { src: '/images/portfolio/backyard-overhead.jpg', label: 'Top-Down Overhead', caption: 'Straight-down map view of lot lines and rooflines' },
  { src: '/images/portfolio/front-overhead-angle.jpg', label: 'Angled Overhead', caption: 'Three-quarter angle highlighting roof and solar detail' },
];
---

<section id="portfolio" class="portfolio">
  <div class="container">
    <p class="kicker">The Work</p>
    <h2>A portfolio worth the altitude</h2>
    <p class="section-intro">
      A selection of recent flights over residential and commercial properties
      in and around Pittsburgh.
    </p>
    <div class="grid">
      {shots.map((shot) => (
        <figure class="shot">
          <img src={shot.src} alt={`${shot.label} — aerial drone photography in the Greater Pittsburgh area`} loading="lazy" width="800" height="600" />
          <figcaption>
            <strong>{shot.label}</strong>
            <span>{shot.caption}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .portfolio {
    background: var(--ink-800);
    border-block: 1px solid var(--ink-600);
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.25rem;
    margin-top: 3rem;
  }

  .shot {
    position: relative;
    margin: 0;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--ink-600);
    aspect-ratio: 4 / 3;
  }

  .shot img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .shot:hover img { transform: scale(1.04); }

  figcaption {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    padding: 2.25rem 1.25rem 1rem;
    background: linear-gradient(to top, rgba(10, 10, 12, 0.92), transparent);
    display: flex;
    flex-direction: column;
  }

  figcaption strong {
    color: var(--cream);
    font-family: var(--font-display);
    font-size: 1.1rem;
  }

  figcaption span {
    font-size: 0.8125rem;
    color: var(--stone-dim);
  }
</style>
