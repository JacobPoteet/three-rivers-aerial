---
// CONTACT FORM SETUP (one-time, ~2 minutes):
// This form posts to Formspree, which works perfectly on static Cloudflare Pages sites.
//   1. Create a free account at https://formspree.io
//   2. Create a new form and copy its ID (looks like "mqkrzvbw")
//   3. Replace YOUR_FORM_ID in the action below
// Until then the form will show Formspree's error page on submit.
const FORM_ACTION = 'https://formspree.io/f/YOUR_FORM_ID';

// Update with your real contact details:
const EMAIL = 'hello@threeriversaerial.com';
const PHONE = '(412) 555-0148';
---

<section id="contact" class="contact">
  <div class="container contact-grid">
    <div>
      <p class="kicker">Get In Touch</p>
      <h2>Let's get your listing off the ground</h2>
      <p class="section-intro">
        Tell us about the property and we'll respond within one business day
        with availability and a quote.
      </p>
      <div class="direct">
        <p><strong>Email</strong> <a href={`mailto:${EMAIL}`}>{EMAIL}</a></p>
        <p><strong>Phone</strong> <a href={`tel:${PHONE.replace(/\D/g, '')}`}>{PHONE}</a></p>
        <p><strong>Service Area</strong> <span>Greater Pittsburgh &amp; surrounding counties</span></p>
      </div>
    </div>
    <form action={FORM_ACTION} method="POST" class="card">
      <div class="row">
        <label>
          Name
          <input type="text" name="name" required autocomplete="name" />
        </label>
        <label>
          Email
          <input type="email" name="email" required autocomplete="email" />
        </label>
      </div>
      <div class="row">
        <label>
          Phone
          <input type="tel" name="phone" autocomplete="tel" />
        </label>
        <label>
          Property Type
          <select name="property_type">
            <option>Residential listing</option>
            <option>Commercial property</option>
            <option>Land / acreage</option>
            <option>Construction progress</option>
            <option>Other</option>
          </select>
        </label>
      </div>
      <label>
        Property Address
        <input type="text" name="address" placeholder="Street, City, PA" />
      </label>
      <label>
        Tell us about the project
        <textarea name="message" rows="4" required></textarea>
      </label>
      <button type="submit" class="btn btn-gold">Send Inquiry</button>
    </form>
  </div>
</section>

<style>
  .contact {
    background: var(--ink-800);
    border-top: 1px solid var(--ink-600);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 4rem;
    align-items: start;
  }

  .direct { margin-top: 2rem; display: grid; gap: 0.4rem; }

  .direct p { margin: 0; font-size: 0.9375rem; }

  .direct strong {
    display: inline-block;
    width: 7.5rem;
    color: var(--cream);
    font-weight: 600;
  }

  form {
    padding: 2.25rem;
    display: grid;
    gap: 1.15rem;
  }

  form:hover { transform: none; }

  .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.15rem;
  }

  label {
    display: grid;
    gap: 0.4rem;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--stone-dim);
  }

  input,
  select,
  textarea {
    background: var(--ink-900);
    border: 1px solid var(--ink-600);
    border-radius: 2px;
    padding: 0.75rem 0.9rem;
    color: var(--cream);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    transition: border-color 0.2s ease;
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--gold-500);
  }

  textarea { resize: vertical; }

  form .btn { justify-content: center; }

  @media (max-width: 820px) {
    .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
    .row { grid-template-columns: 1fr; }
  }
</style>
