---
// Contact form posts to Formspree (works on static Cloudflare Pages).
// Submissions are emailed to the address configured on the Formspree form.
// The script at the bottom submits via fetch and shows an inline success
// message; with JS disabled it falls back to a normal POST.
const FORM_ACTION = 'https://formspree.io/f/xdarrkor';

// Contact details live in src/data/site.ts so they stay in sync with the
// structured data / social meta in Base.astro.
import { site } from '../data/site';
const EMAIL = site.email;
const PHONE = site.phone;
---

<section id="contact" class="contact">
  <div class="container contact-grid">
    <div>
      <p class="kicker">Get In Touch</p>
      <h2>Let's get your listing off the ground</h2>
      <p class="section-intro">
        Tell us about the property and we'll respond within one business day
        with availability and a quote.
      </p>
      <div class="direct">
        <p><strong>Email</strong> <a href={`mailto:${EMAIL}`}>{EMAIL}</a></p>
        <p><strong>Phone</strong> <a href={`tel:${PHONE.replace(/\D/g, '')}`}>{PHONE}</a></p>
        <p><strong>Service Area</strong> <span>Greater Pittsburgh &amp; surrounding counties</span></p>
      </div>
    </div>
    <div class="form-col">
    <form id="contact-form" action={FORM_ACTION} method="POST" class="card">
      <input type="hidden" name="_subject" value="New inquiry from threeriversaerial.com" />
      <div class="row">
        <label>
          Name
          <input type="text" name="name" required autocomplete="name" />
        </label>
        <label>
          Email
          <input type="email" name="email" required autocomplete="email" />
        </label>
      </div>
      <div class="row">
        <label>
          Phone
          <input type="tel" name="phone" autocomplete="tel" />
        </label>
        <label>
          Property Type
          <select name="property_type">
            <option>Residential listing</option>
            <option>Commercial property</option>
            <option>Land / acreage</option>
            <option>Construction progress</option>
            <option>Other</option>
          </select>
        </label>
      </div>
      <label>
        Property Address
        <input type="text" name="address" placeholder="Street, City, PA" />
      </label>
      <label>
        Tell us about the project
        <textarea name="message" rows="4" required></textarea>
      </label>
      <button type="submit" class="btn btn-gold">Send Inquiry</button>
      <p id="contact-error" class="form-error" hidden role="alert">
        Something went wrong sending your message. Please email
        <a href={`mailto:${EMAIL}`}>{EMAIL}</a> directly.
      </p>
    </form>
      <div id="contact-success" class="form-status card" hidden>
        <h3>Thanks — your inquiry is in.</h3>
        <p>We'll get back to you within one business day with availability and a quote.</p>
      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  if (form) {
    const errorEl = document.getElementById('contact-error');
    const successEl = document.getElementById('contact-success');
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      const label = btn.textContent;
      btn.disabled = true;
      btn.textContent = 'Sending…';
      if (errorEl) errorEl.hidden = true;

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
          headers: { Accept: 'application/json' },
        });
        if (!response.ok) throw new Error('Request failed');
        form.hidden = true;
        if (successEl) successEl.hidden = false;
      } catch {
        btn.disabled = false;
        btn.textContent = label;
        if (errorEl) errorEl.hidden = false;
      }
    });
  }
</script>

<style>
  .contact {
    background: var(--ink-800);
    border-top: 1px solid var(--ink-600);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 1.15fr;
    gap: 4rem;
    align-items: start;
  }

  .direct { margin-top: 2rem; display: grid; gap: 0.4rem; }

  .direct p { margin: 0; font-size: 0.9375rem; }

  .direct strong {
    display: inline-block;
    width: 7.5rem;
    color: var(--cream);
    font-weight: 600;
  }

  form {
    padding: 2.25rem;
    display: grid;
    gap: 1.15rem;
  }

  form:hover { transform: none; }

  .row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.15rem;
  }

  label {
    display: grid;
    gap: 0.4rem;
    font-size: 0.8125rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--stone-dim);
  }

  input,
  select,
  textarea {
    background: var(--ink-900);
    border: 1px solid var(--ink-600);
    border-radius: 2px;
    padding: 0.75rem 0.9rem;
    color: var(--cream);
    font-family: var(--font-body);
    font-size: 0.9375rem;
    transition: border-color 0.2s ease;
  }

  input:focus,
  select:focus,
  textarea:focus {
    outline: none;
    border-color: var(--gold-500);
  }

  textarea { resize: vertical; }

  form .btn { justify-content: center; }

  .form-col { min-width: 0; }

  .form-status { padding: 2.25rem; }

  .form-status h3 { color: var(--gold-500); margin-bottom: 0.5rem; }

  .form-status p { color: var(--stone-dim); font-size: 0.9375rem; margin: 0; }

  .form-error {
    margin: 0.25rem 0 0;
    font-size: 0.875rem;
    color: var(--cream);
  }

  .form-error a { color: var(--gold-500); }

  @media (max-width: 820px) {
    .contact-grid { grid-template-columns: 1fr; gap: 3rem; }
    .row { grid-template-columns: 1fr; }
  }
</style>
