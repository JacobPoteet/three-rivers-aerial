---
interface Props {
  size?: number;
}
const { size = 34 } = Astro.props;
---

<span class="logo">
  <svg width={size} height={size} viewBox="0 0 64 64" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <!-- Allegheny (from upper-right) and Monongahela (from lower-right) meet at the Point, forming the Ohio flowing out to the left -->
    <path d="M56 10 C 44 22, 38 27, 30 32" stroke="var(--gold-500)" stroke-width="4" fill="none" stroke-linecap="round"/>
    <path d="M56 54 C 44 42, 38 37, 30 32" stroke="var(--gold-500)" stroke-width="4" fill="none" stroke-linecap="round"/>
    <path d="M30 32 L 6 32" stroke="var(--gold-500)" stroke-width="4" fill="none" stroke-linecap="round"/>
  </svg>
  <span class="logo-text">
    <strong>Three Rivers</strong>
    <em>Aerial Co.</em>
  </span>
</span>

<style>
  .logo {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.1;
  }

  .logo-text strong {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1.2rem;
    color: var(--cream);
    letter-spacing: 0.02em;
  }

  .logo-text em {
    font-style: normal;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--gold-500);
  }
</style>
