---
import Logo from './Logo.astro';

const links = [
  { href: '#services', label: 'Services' },
  { href: '#portfolio', label: 'Portfolio' },
  { href: '#pricing', label: 'Pricing' },
  { href: '#about', label: 'About' },
];
---

<header class="nav-wrap">
  <div class="container nav">
    <a href="#top" class="brand" aria-label="Three Rivers Aerial Co., home">
      <Logo />
    </a>
    <nav class="desktop-nav" aria-label="Primary">
      <ul>
        {links.map((link) => (
          <li><a href={link.href}>{link.label}</a></li>
        ))}
      </ul>
    </nav>
    <a href="#contact" class="btn btn-gold nav-cta">Book a Flight</a>
    <button
      class="nav-toggle"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="mobile-menu"
    >
      <span></span><span></span><span></span>
    </button>
  </div>
  <nav class="mobile-menu" id="mobile-menu" aria-label="Mobile" hidden>
    <ul>
      {links.map((link) => (
        <li><a href={link.href}>{link.label}</a></li>
      ))}
      <li><a href="#contact" class="btn btn-gold">Book a Flight</a></li>
    </ul>
  </nav>
</header>

<script>
  const wrap = document.querySelector('.nav-wrap');
  const toggle = document.querySelector<HTMLButtonElement>('.nav-toggle');
  const menu = document.getElementById('mobile-menu');

  if (wrap && toggle && menu) {
    const setOpen = (open: boolean) => {
      toggle.setAttribute('aria-expanded', String(open));
      toggle.setAttribute('aria-label', open ? 'Close menu' : 'Open menu');
      menu.hidden = !open;
      wrap.classList.toggle('open', open);
    };

    toggle.addEventListener('click', () => {
      setOpen(toggle.getAttribute('aria-expanded') !== 'true');
    });

    // Close after tapping a link, and on Escape.
    menu.querySelectorAll('a').forEach((a) =>
      a.addEventListener('click', () => setOpen(false))
    );
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') setOpen(false);
    });
  }
</script>

<style>
  .nav-wrap {
    position: fixed;
    inset-inline: 0;
    top: 0;
    z-index: 100;
    background: rgba(10, 10, 12, 0.82);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-bottom: 1px solid rgba(212, 175, 55, 0.14);
  }

  .nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-block: 0.85rem;
  }

  .desktop-nav ul {
    display: flex;
    gap: 2.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .desktop-nav a {
    font-size: 0.875rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--stone);
  }

  .desktop-nav a:hover { color: var(--gold-400); }

  .nav-cta {
    padding: 0.6rem 1.4rem;
    font-size: 0.8125rem;
  }

  /* Hamburger button — hidden on desktop */
  .nav-toggle {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 0;
    background: transparent;
    border: 0;
    cursor: pointer;
  }

  .nav-toggle span {
    display: block;
    width: 24px;
    height: 2px;
    margin-inline: auto;
    background: var(--cream);
    transition: transform 0.25s ease, opacity 0.2s ease;
  }

  .nav-wrap.open .nav-toggle span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .nav-wrap.open .nav-toggle span:nth-child(2) { opacity: 0; }
  .nav-wrap.open .nav-toggle span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile dropdown panel */
  .mobile-menu {
    border-top: 1px solid rgba(212, 175, 55, 0.14);
    background: rgba(10, 10, 12, 0.98);
  }

  .mobile-menu[hidden] { display: none; }

  .mobile-menu ul {
    list-style: none;
    margin: 0;
    padding: 1rem clamp(1.25rem, 4vw, 2.5rem) 1.75rem;
    display: grid;
    gap: 0.25rem;
  }

  .mobile-menu a:not(.btn) {
    display: block;
    padding: 0.85rem 0;
    font-size: 0.95rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--stone);
    border-bottom: 1px solid var(--ink-600);
  }

  .mobile-menu a:not(.btn):hover { color: var(--gold-400); }

  .mobile-menu .btn {
    margin-top: 1rem;
    justify-content: center;
  }

  @media (max-width: 820px) {
    .desktop-nav,
    .nav-cta { display: none; }
    .nav-toggle { display: flex; }
  }
</style>
