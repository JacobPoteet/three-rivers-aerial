---
// Hero with an aerial video backdrop that plays once and holds its last frame.
// The video lives in public/videos/hero.mp4; poster (first frame) is
// public/images/hero-poster.jpg. Add public/videos/hero.webm as a smaller
// alternative source when available.
---

<section class="hero" id="top">
  <div class="hero-bg" aria-hidden="true">
    <video
      class="hero-video"
      autoplay
      muted
      playsinline
      preload="auto"
      poster="/images/hero-poster.jpg"
    >
      <source src="/videos/hero.mp4" type="video/mp4" />
    </video>
    <div class="hero-scrim"></div>
  </div>
  <div class="container hero-inner">
    <p class="kicker">Pittsburgh, Pennsylvania</p>
    <h1>Real estate, seen<br />from a <span class="text-gold">higher&nbsp;point</span>.</h1>
    <p class="lede">
      Cinematic aerial photography and videography for residential and commercial
      properties across the Greater Pittsburgh area. Listings with aerial media
      sell faster — give yours the view it deserves.
    </p>
    <div class="hero-actions">
      <a href="#contact" class="btn btn-gold">Book a Flight</a>
      <a href="#portfolio" class="btn btn-outline">View the Work</a>
    </div>
  </div>
  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    padding-block: 8rem 6rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
    opacity: 0;
    animation: hero-fade-in 1.4s ease-out 0.15s forwards;
  }

  @keyframes hero-fade-in {
    to { opacity: 1; }
  }

  .hero-video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
    opacity: 0.9;
  }

  /* Darkens the video toward the left and bottom, where the headline and
     copy sit, so the text stays legible over bright footage. */
  .hero-scrim {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background:
      linear-gradient(
        to right,
        rgba(10, 10, 12, 0.82) 0%,
        rgba(10, 10, 12, 0.45) 42%,
        rgba(10, 10, 12, 0) 78%
      ),
      linear-gradient(
        to bottom,
        rgba(10, 10, 12, 0.35) 0%,
        rgba(10, 10, 12, 0) 30%
      );
  }

  .hero-fade {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 30%;
    background: linear-gradient(to bottom, transparent, var(--ink-900));
    pointer-events: none;
  }

  .hero-inner { max-width: 780px; }

  .lede {
    font-size: clamp(1.0625rem, 2vw, 1.25rem);
    max-width: 560px;
    color: var(--stone);
    margin-bottom: 2.25rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-bg {
      animation: none;
      opacity: 1;
    }
  }
</style>
