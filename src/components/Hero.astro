---
// Hero with a stylized Pittsburgh skyline backdrop.
// Swap the .hero-bg SVG for a real hero photo once you have one:
// put it in public/images/ and set it as a background-image on .hero.
---

<section class="hero" id="top">
  <div class="hero-bg" aria-hidden="true">
    <img src="/images/hero-skyline.svg" alt="" loading="eager" />
  </div>
  <div class="container hero-inner">
    <p class="kicker">Pittsburgh, Pennsylvania</p>
    <h1>Real estate, seen<br />from a <span class="text-gold">higher&nbsp;point</span>.</h1>
    <p class="lede">
      Cinematic aerial photography and videography for residential and commercial
      properties across the Greater Pittsburgh area. Listings with aerial media
      sell faster — give yours the view it deserves.
    </p>
    <div class="hero-actions">
      <a href="#contact" class="btn btn-gold">Book a Flight</a>
      <a href="#portfolio" class="btn btn-outline">View the Work</a>
    </div>
  </div>
  <div class="hero-fade" aria-hidden="true"></div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 92vh;
    display: flex;
    align-items: center;
    padding-block: 8rem 6rem;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center bottom;
    opacity: 0.9;
  }

  .hero-fade {
    position: absolute;
    inset-inline: 0;
    bottom: 0;
    height: 30%;
    background: linear-gradient(to bottom, transparent, var(--ink-900));
    pointer-events: none;
  }

  .hero-inner { max-width: 780px; }

  .lede {
    font-size: clamp(1.0625rem, 2vw, 1.25rem);
    max-width: 560px;
    color: var(--stone);
    margin-bottom: 2.25rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
  }
</style>
