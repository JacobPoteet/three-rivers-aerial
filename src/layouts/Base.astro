---
import '../styles/global.css';
import { site } from '../data/site';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Three Rivers Aerial Co. | Drone Photography for Pittsburgh Real Estate',
  description =
    'FAA-licensed aerial photography and videography for residential and commercial real estate in Pittsburgh, PA. Cinematic drone media that sells properties faster.',
} = Astro.props;

// Absolute URLs for canonical + social cards (fall back to the configured site).
const base = Astro.site ?? new URL('https://three-rivers-aerial.pages.dev');
const canonical = new URL(Astro.url.pathname, base).href;
const ogImage = new URL('/images/og.jpg', base).href;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  '@id': `${base.href}#business`,
  name: site.name,
  legalName: site.legalName,
  description: site.description,
  url: base.href,
  image: ogImage,
  logo: new URL('/favicon.svg', base).href,
  email: site.email,
  telephone: site.phone,
  priceRange: site.priceRange,
  address: {
    '@type': 'PostalAddress',
    addressLocality: site.locality,
    addressRegion: site.region,
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: site.geo.latitude,
    longitude: site.geo.longitude,
  },
  areaServed: site.serviceAreas.map((area) => ({
    '@type': 'City',
    name: area,
  })),
  ...(site.socials.length ? { sameAs: site.socials } : {}),
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Drone Media Services',
    itemListElement: site.services.map((service) => ({
      '@type': 'Offer',
      itemOffered: {
        '@type': 'Service',
        name: service.name,
        description: service.description,
      },
    })),
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#0a0a0c" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Open Graph / social sharing -->
    <meta property="og:site_name" content={site.name} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
  </body>
</html>
